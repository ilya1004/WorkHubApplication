{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity_service": {
        "ClusterId": "identity_cluster",
        "Match": {
          "Path": "/identity-service/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/identity-service"
          }
        ]
      },
      "projects_service": {
        "ClusterId": "projects_cluster",
        "Match": {
          "Path": "/projects-service/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/projects-service"
          }
        ]
      },
      "chat_service": {
        "ClusterId": "chat_cluster",
        "Match": {
          "Path": "/chat-service/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/chat-service"
          }
        ]
      },
      "payments_service": {
        "ClusterId": "payments_cluster",
        "Match": {
          "Path": "/payments-service/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/payments-service"
          }
        ]
      }
    },
    "Clusters": {
      "identity_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7080"
          }
        }
      },
      "projects_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7081"
          }
        }
      },
      "chat_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7082"
          }
        }
      },
      "payments_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7083"
          }
        }
      }
    }
  }
}
