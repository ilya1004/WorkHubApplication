{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgresConnectionPrimaryDb": "Host=postgres_primary;Port=5432;Database=ProjectsServiceDb;Username=postgres;Password=passpass_primary;Include Error Detail=true",
    "PostgresConnectionReplicaDb": "Host=postgres_replica;Port=5432;Database=ProjectsServiceDb;Username=postgres;Password=passpass_primary;Include Error Detail=true",
    "PostgresConnectionHangfireDb": "Host=postgres_hangfire;Port=5432;Database=ProjectsServiceHangfireDb;Username=postgres;Password=passpass;Include Error Detail=true",
    "RedisConnection": "redis:6379,password=redispass,defaultDatabase=1"
  },
  "JwtSettings": {
    "SecretKey": "my_secret_key_my_secret_key_my_secret_key_my_secret_key_my_secret_key",
    "Issuer": "IdentityService",
    "Audience": "WorkHubServices"
  },
  "KafkaSettings": {
    "BootstrapServers": "kafka:9092",
    "PaymentIntentSavingTopic": "payment_intent_saving",
    "PaymentCancellationTopic" : "payment_cancellation"
  },
  "ProjectsSettings": {
    "MaxWorkDeadlineExpirationTimeInDays": 30,
    "MaxWorkStartExpirationTimeInDays": 14
  },
